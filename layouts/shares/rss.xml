{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }} — {{ .Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent shares from {{ .Site.Title }}</description>
    <language>{{ .Site.Language.Lang }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- with .OutputFormats.Get "rss" -}}
    <atom:link href="{{ .RelPermalink }}" rel="self" type="application/rss+xml"/>
    {{- end -}}
    {{ range .Pages.ByDate.Reverse }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Params.link }}</link>
      <guid>{{ .Params.link }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <description>{{- .Content | transform.HTMLEscape -}}</description>
      {{ range .Params.tags }}
      <category>{{ . }}</category>
      {{ end }}
    </item>
    {{ end }}
  </channel>
</rss>
